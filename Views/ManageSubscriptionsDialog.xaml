<?xml version="1.0" encoding="utf-8"?>
<ContentDialog x:Class="AnywhereWinUI.Views.ManageSubscriptionsDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:controls="using:CommunityToolkit.WinUI.Controls"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d"
               DefaultButton="Primary">

    <ContentDialog.Resources>
        <!-- Suppress default ContentDialog title area — we draw our own -->
        <x:Double x:Key="ContentDialogMinWidth">360</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">460</x:Double>
    </ContentDialog.Resources>

    <!-- Root content: title row + page body -->
    <StackPanel Spacing="16" Margin="0,4,0,0" Width="360">

        <!-- Title row: dynamic title + icon segmented switcher -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock x:Name="DialogTitleText"
                       Grid.Column="0"
                       Text="添加订阅"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <controls:Segmented x:Name="PageSegmented"
                                Grid.Column="1"
                                HorizontalAlignment="Right"
                                SelectedIndex="0"
                                SelectionChanged="PageSegmented_SelectionChanged">
                <controls:Segmented.Resources>
                    <SolidColorBrush x:Key="SegmentedItemBackgroundPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="SegmentedItemBorderBrushPointerOver" Color="Transparent" />
                </controls:Segmented.Resources>
                <!-- Add sub icon -->
                <controls:SegmentedItem Padding="0" ToolTipService.ToolTip="添加订阅">
                    <controls:SegmentedItem.Icon>
                        <FontIcon Glyph="&#xED0E;" FontSize="14" />
                    </controls:SegmentedItem.Icon>
                </controls:SegmentedItem>
                <!-- Manage subs icon -->
                <controls:SegmentedItem Padding="0" ToolTipService.ToolTip="管理订阅">
                    <controls:SegmentedItem.Icon>
                        <FontIcon Glyph="&#xEBC3;" FontSize="14" />
                    </controls:SegmentedItem.Icon>
                </controls:SegmentedItem>
            </controls:Segmented>
        </Grid>

        <!-- ── Add Page ─────────────────────────────────────────────────────── -->
        <StackPanel x:Name="AddPagePanel" Spacing="14">
            <TextBox x:Name="UrlInput"
                     Header="订阅链接"
                     PlaceholderText="https://..."
                     TextWrapping="Wrap"
                     TextChanged="UrlInput_TextChanged" />
            <TextBox x:Name="NameInput"
                     Header="备注名称（可选）"
                     PlaceholderText="留空则使用链接域名" />
            <TextBlock Text="将自动拉取并导入订阅中的全部节点"
                       FontSize="12"
                       Opacity="0.65" />
        </StackPanel>

        <!-- ── Manage Page ───────────────────────────────────────────────────── -->
        <Grid x:Name="ManagePagePanel" Visibility="Collapsed">
            <!-- Empty state -->
            <TextBlock x:Name="EmptyStateText"
                       Text="暂无订阅"
                       HorizontalAlignment="Center"
                       Margin="0,48,0,48"
                       FontSize="14"
                       Opacity="0.6"
                       Visibility="Collapsed" />

            <!-- Subscription list -->
            <ScrollViewer x:Name="SubScrollViewer"
                          MaxHeight="440"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="SubsListPanel" Spacing="0" />
            </ScrollViewer>
        </Grid>

    </StackPanel>
</ContentDialog>

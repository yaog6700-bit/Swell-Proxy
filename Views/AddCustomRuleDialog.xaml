<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="AnywhereWinUI.Views.AddCustomRuleDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="添加规则"
    PrimaryButtonText="添加"
    CloseButtonText="取消"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="340" MaxWidth="420">
        <StackPanel Spacing="6">
            <TextBlock Text="规则类型"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ComboBox x:Name="TypeComboBox"
                      SelectedIndex="0"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem Content="域名" Tag="domain" />
                <ComboBoxItem Content="IP / CIDR" Tag="ip" />
                <ComboBoxItem Content="进程" Tag="process" />
                <ComboBoxItem Content="混合" Tag="mixed" />
            </ComboBox>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="匹配内容"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBox x:Name="MatchTextBox"
                     PlaceholderText="youtube.com 或 geosite:cn" />

            <StackPanel x:Name="BrowsePanel"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="Collapsed">
                <Button x:Name="BrowseButton">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE8E5;" FontSize="12" />
                        <TextBlock Text="浏览 exe..." />
                    </StackPanel>
                </Button>
                <ComboBox x:Name="BrowseFormatComboBox"
                          SelectedIndex="0"
                          MinWidth="130">
                    <ComboBoxItem Content="进程名" Tag="name" />
                    <ComboBoxItem Content="完整路径" Tag="path" />
                </ComboBox>
            </StackPanel>

            <TextBlock x:Name="HintTextBlock"
                       Text="支持精确域名、regex:、regexp:、domain_suffix:、geosite:、ruleset:https://.../*.srs 前缀。"
                       FontSize="11"
                       Opacity="0.6"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="出站方式"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <ComboBox x:Name="OutboundComboBox"
                      HorizontalAlignment="Stretch" />
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   Text="请填写匹配内容。"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   FontSize="11"
                   Visibility="Collapsed" />
    </StackPanel>
</ContentDialog>

<Page
    x:Class="AnywhereWinUI.Views.TrafficPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUIEx"
    xmlns:viewmodels="using:AnywhereWinUI.ViewModels"
    xmlns:converters="using:AnywhereWinUI.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:HeatmapColorConverter x:Key="HeatmapColorConverter"/>
        
        <!-- 纯文本风格的 RadioButton 样式（无圆圈，选中时加粗变色） -->
        <Style x:Key="TextRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <Setter Target="ContentPresenter.FontWeight" Value="SemiBold"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter" Content="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
            <TextBlock Text="流量与数据" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="实时监控当前会话及历史网络流量统计" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="0,0,16,0" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="24" RowSpacing="24" MaxWidth="1200" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 1. 实时速率 (Row 0, Col 0) -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="Transparent" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="实时速率" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" x:Name="ActiveConnectionsText" Text="{x:Bind ViewModel.ActiveConnectionsText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" FontFamily="Consolas" FontSize="14"/>
                    </Grid>
                </Border>

                <!-- 2. 核心运行状态 (Row 0, Col 1) -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="Transparent" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE93E;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="核心连接状态" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{x:Bind ViewModel.StatusDotFill, Mode=OneWay}"/>
                            <TextBlock x:Name="StatusText" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 3. 当前会话数据卡片 (Row 1, Col 0) -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="Transparent" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="当前会话（仅代理流量）" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Grid ColumnDefinitions="*,*,*">
                            <!-- 上传 -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE898;" Foreground="#FF007ACC" FontSize="16"/>
                                    <TextBlock Text="上传流量" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="SessionUploadText" Text="{x:Bind ViewModel.SessionUploadText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <!-- 下载 -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" Foreground="#FF107C41" FontSize="16"/>
                                    <TextBlock Text="下载流量" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="SessionDownloadText" Text="{x:Bind ViewModel.SessionDownloadText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <!-- 总计 -->
                            <StackPanel Grid.Column="2" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D7;" Foreground="#FF8A2BE2" FontSize="16"/>
                                    <TextBlock Text="会话总量" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="SessionTotalText" Text="{x:Bind ViewModel.SessionTotalText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 4. 本月累计数据 (Row 1, Col 1) -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="Transparent" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="本月累计" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Grid ColumnDefinitions="*,*,*">
                            <!-- 上传 -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE898;" Foreground="#FF007ACC" FontSize="16"/>
                                    <TextBlock Text="本月上传" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="MonthUploadText" Text="{x:Bind ViewModel.MonthUploadText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <!-- 下载 -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE896;" Foreground="#FF107C41" FontSize="16"/>
                                    <TextBlock Text="本月下载" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="MonthDownloadText" Text="{x:Bind ViewModel.MonthDownloadText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                            <!-- 总计 -->
                            <StackPanel Grid.Column="2" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D7;" Foreground="#FF8A2BE2" FontSize="16"/>
                                    <TextBlock Text="本月总计" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="MonthTotalText" Text="{x:Bind ViewModel.MonthTotalText, Mode=OneWay}" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 5. 30天历史柱状图 (Row 2, ColSpan 2) -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Background="Transparent" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="24">
                    <StackPanel Spacing="16">
                        <TextBlock Text="每日代理流量（近 30 天，单位: MB）" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" HorizontalScrollMode="Enabled">
                            <ItemsControl x:Name="ChartItemsControl" ItemsSource="{x:Bind ViewModel.ChartItems, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="16" Height="220" VerticalAlignment="Bottom"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:TrafficChartViewModel">
                                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Spacing="8" Width="40">
                                            <Grid Height="150" VerticalAlignment="Bottom" Width="20">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <Border Grid.Row="1" Background="#FF007ACC" CornerRadius="2,2,0,0" Height="{x:Bind UploadHeight}" Width="8" ToolTipService.ToolTip="{x:Bind UploadTooltip}"/>
                                                <Border Grid.Row="2" Background="#FF107C41" CornerRadius="0,0,2,2" Height="{x:Bind DownloadHeight}" Width="8" ToolTipService.ToolTip="{x:Bind DownloadTooltip}"/>
                                            </Grid>
                                            
                                            <TextBlock Text="{x:Bind DayLabel}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- 6. 年度流量热力图 (Row 3, ColSpan 2) -->
                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24">
                    <StackPanel Spacing="20">

                        <!-- 标题行 + 视图切换 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="流量热力图" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <RadioButton x:Name="HeatmapDailyBtn" Content="每日" GroupName="HeatmapMode"
                                             IsChecked="True" Checked="HeatmapDailyBtn_Checked"
                                             Style="{StaticResource TextRadioButtonStyle}"/>
                                <RadioButton x:Name="HeatmapWeeklyBtn" Content="每周" GroupName="HeatmapMode"
                                             Checked="HeatmapWeeklyBtn_Checked"
                                             Style="{StaticResource TextRadioButtonStyle}"/>
                                <RadioButton x:Name="HeatmapCumulativeBtn" Content="累计" GroupName="HeatmapMode"
                                             Checked="HeatmapCumulativeBtn_Checked"
                                             Style="{StaticResource TextRadioButtonStyle}"/>
                            </StackPanel>
                        </Grid>


                        <!-- 热力图主体：7行 × 52列，行=周几，列=第几周 -->
                        <!-- 热力图与底部月份标签 -->
                        <!-- 增加 MinHeight 防止高度塌陷；HorizontalAlignment="Center" 让热力图在宽卡片中居中，平衡左右留白 -->
                        <StackPanel Spacing="8" MinHeight="130" HorizontalAlignment="Center">
                            <ItemsControl x:Name="HeatmapControl"
                                          ItemsSource="{x:Bind ViewModel.HeatmapCells, Mode=OneWay}"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Vertical" MaximumRowsOrColumns="7"
                                                       HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <!-- 格子间距，上下左右各 1.5，总共占据 10+3=13 像素宽度 -->
                                        <Setter Property="Margin" Value="1.5"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:HeatmapCellViewModel">
                                        <Border Width="10" Height="10"
                                                CornerRadius="2"
                                                Background="{x:Bind ColorLevel, Converter={StaticResource HeatmapColorConverter}}"
                                                ToolTipService.ToolTip="{x:Bind Tooltip}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 月份标签（宽度对齐热力图的列） -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.MonthLabels, Mode=OneWay}" HorizontalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <!-- 每列宽度 13px (10 + 1.5 + 1.5) -->
                                        <Border Width="13" Height="20">
                                            <!-- 使用 Canvas 允许文字突破 13px 宽度向右溢出，防止两位数月份被截断，同时防止底部被截断 -->
                                            <Canvas>
                                                <TextBlock Text="{x:Bind}" FontSize="11" 
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Canvas>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 图例说明（如果不需要也可以直接注释掉，这里保留了和浅色模式相匹配的柔和颜色） -->
                        <!--
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <TextBlock Text="少" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="#F3F4F6"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="#CBE2FE"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="#8CB8FE"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="#4B8DF8"/>
                            <Border Width="10" Height="10" CornerRadius="2" Background="#2B66E0"/>
                            <TextBlock Text="多" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        -->

                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

<Page
    x:Class="AnywhereWinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="12,24,24,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="228" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Master Panel: Settings Categories List -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="12,0,0,16" Spacing="4">
                <TextBlock Text="系统设置" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock Text="配置客户端偏好与核心" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Categories List -->
            <ListView x:Name="CategoriesListView"
                      Grid.Row="1"
                      SelectionMode="Single"
                      SelectedIndex="0"
                      SelectionChanged="CategoriesListView_SelectionChanged"
                      Background="Transparent"
                      Padding="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="MinHeight" Value="36"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Grid Background="Transparent">
                                        <!-- Interactive background -->
                                        <Rectangle x:Name="BackgroundElement"
                                                   Fill="Transparent"
                                                   RadiusX="6" RadiusY="6"/>
                                        <!-- Content -->
                                        <ContentPresenter x:Name="ContentPresenter"
                                                          Padding="16,10"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center"/>
                                        <!-- Pill Indicator -->
                                        <Rectangle x:Name="PillIndicator"
                                                   Width="3"
                                                   Height="16"
                                                   RadiusX="1.5" RadiusY="1.5"
                                                   Fill="{ThemeResource SystemAccentColor}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="2,0,0,0"
                                                   Opacity="0"/>
                                        
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualStateGroup.Transitions>
                                                    <VisualTransition GeneratedDuration="0:0:0.15"/>
                                                </VisualStateGroup.Transitions>
                                                <VisualState x:Name="Normal"/>
                                                <VisualState x:Name="PointerOver">
                                                    <VisualState.Setters>
                                                        <Setter Target="BackgroundElement.Fill" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="Pressed">
                                                    <VisualState.Setters>
                                                        <Setter Target="BackgroundElement.Fill" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Target="BackgroundElement.Fill" Value="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                                        <Setter Target="PillIndicator.Opacity" Value="1"/>
                                                        <Setter Target="PillIndicator.Height" Value="16"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="PointerOverSelected">
                                                    <VisualState.Setters>
                                                        <Setter Target="BackgroundElement.Fill" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                        <Setter Target="PillIndicator.Opacity" Value="1"/>
                                                        <Setter Target="PillIndicator.Height" Value="16"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                                <VisualState x:Name="PressedSelected">
                                                    <VisualState.Setters>
                                                        <Setter Target="BackgroundElement.Fill" Value="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                                                        <Setter Target="PillIndicator.Opacity" Value="1"/>
                                                        <Setter Target="PillIndicator.Height" Value="12"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateManager.VisualStateGroups>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                
                <ListViewItem Tag="Appearance" 
                              PointerEntered="AppearanceItem_PointerEntered" 
                              PointerExited="AppearanceItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconAppearance" Glyph="&#xE790;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="个性化外观" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Colors" 
                              PointerEntered="ColorsItem_PointerEntered" 
                              PointerExited="ColorsItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconColors" Glyph="&#xE771;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="协议标识" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Routing" 
                              PointerEntered="RoutingItem_PointerEntered" 
                              PointerExited="RoutingItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconRouting" Glyph="&#xE909;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="路由分流" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="DnsSettings" 
                              PointerEntered="DnsSettingsItem_PointerEntered" 
                              PointerExited="DnsSettingsItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconDnsSettings" Glyph="&#xE81E;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="DNS 与解析" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Tailscale"
                              PointerEntered="TailscaleItem_PointerEntered"
                              PointerExited="TailscaleItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconTailscale" Glyph="&#xE703;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="Tailscale 组网" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Autostart" 
                              PointerEntered="AutostartItem_PointerEntered" 
                              PointerExited="AutostartItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconAutostart" Glyph="&#xE7E8;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="开机与启动" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Backup" 
                              PointerEntered="BackupItem_PointerEntered" 
                              PointerExited="BackupItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*">
                        <FontIcon x:Name="IconBackup" Glyph="&#xE753;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="备份与恢复" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="About" 
                              PointerEntered="AboutItem_PointerEntered" 
                              PointerExited="AboutItem_PointerExited">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                        <FontIcon x:Name="IconAbout" Glyph="&#xE946;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="关于与内核" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Visibility="{x:Bind MainViewModel.UpdateBadgeVisibility, Mode=OneWay}">
                            <Border Background="{ThemeResource SystemFillColorCriticalBrush}" CornerRadius="4" Padding="4,1">
                                <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </Border>
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource SystemFillColorCriticalBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </ListViewItem>
            </ListView>
        </Grid>

        <!-- Sidebar Divider -->
        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Stretch" Margin="0,0,0,0" />

        <!-- Right Detail Panel: Settings Content Details -->
        <Grid Grid.Column="2" Margin="24,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Detail Title Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="4">
                <TextBlock x:Name="DetailCategoryTitle" Text="个性化外观" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="DetailCategorySubtitle" Text="自定义主题风格、背景材质与界面显示细节" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <Grid Width="620" HorizontalAlignment="Left" Padding="0,0,12,24">
                    
                    <!-- Panel 1: 个性化外观 -->
                    <StackPanel x:Name="AppearancePanel" Spacing="12" Visibility="Visible">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <TextBlock Text="外观模式与背景材质" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <!-- Theme Selection Card -->
                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="全局色彩主题" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="切换客户端的明暗显示状态" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <controls:Segmented Grid.Column="1" x:Name="ThemeSegmented" SelectionChanged="ThemeSegmented_SelectionChanged" VerticalAlignment="Center">
                                    <controls:SegmentedItem Content="浅色" Tag="Light" Padding="14,6">
                                        <controls:SegmentedItem.Icon>
                                            <FontIcon Glyph="&#xE706;" FontSize="16" />
                                        </controls:SegmentedItem.Icon>
                                    </controls:SegmentedItem>
                                    <controls:SegmentedItem Content="深色" Tag="Dark" Padding="14,6">
                                        <controls:SegmentedItem.Icon>
                                            <FontIcon Glyph="&#xE708;" FontSize="16" />
                                        </controls:SegmentedItem.Icon>
                                    </controls:SegmentedItem>
                                    <controls:SegmentedItem Content="跟随系统" Tag="Default" Padding="14,6">
                                        <controls:SegmentedItem.Icon>
                                            <FontIcon Glyph="&#xE770;" FontSize="16" />
                                        </controls:SegmentedItem.Icon>
                                    </controls:SegmentedItem>
                                </controls:Segmented>
                            </Grid>
                        </Border>

                        <!-- Backdrop Selection Card -->
                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="窗口材质背景" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="切换客户端窗口的背景毛玻璃样式效果" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" x:Name="BackdropComboBox" MinWidth="160" VerticalAlignment="Center" SelectionChanged="BackdropComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Mica (原生云母)" Tag="Mica"/>
                                    <ComboBoxItem Content="Acrylic (经典亚克力)" Tag="Acrylic"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Classic Dashboard Switch -->
                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="启用经典控制台首页" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="显示或隐藏左侧边栏的「仪表盘」选项（服务器页面已包含大多数控制台内容）" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnableClassicDashboard, Mode=TwoWay}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Privacy Mode Switch -->
                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="全局隐私保护模式" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="开启后每次启动应用都需要输入密码，以防止他人查看您的节点和配置" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.IsPrivacyModeActive, Mode=TwoWay}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Plugins System Switch -->
                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="启用插件系统" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="开启后侧边栏将显示「插件」入口，支持加载 JavaScript 插件扩展客户端功能。关闭后插件不会被加载，与未安装插件系统完全一致" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnablePlugins, Mode=TwoWay}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Panel: Tailscale 组网 -->
                    <StackPanel x:Name="TailscalePanel" Spacing="12" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <TextBlock Text="Tailscale 私有组网" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel>

                                <!-- 总开关 -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,4,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE703;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="启用 Tailscale Endpoint" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="将 sing-box 作为 Tailscale 节点加入私有网络（tailnet），需要 sing-box 核心支持 Tailscale" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnableTailscale, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Auth Key -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8D7;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="授权 Key (Auth Key)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="Tailscale 预授权 Key（tskey-auth-...），留空则启动时在日志中显示登录 URL" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <PasswordBox Grid.Column="2" Width="220" PlaceholderText="tskey-auth-..." Password="{x:Bind ViewModel.TailscaleAuthKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Hostname -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8F4;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="节点主机名 (Hostname)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="此节点在 tailnet 中显示的名称，留空则使用系统主机名" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="2" Width="220" PlaceholderText="my-pc" Text="{x:Bind ViewModel.TailscaleHostname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- State Directory -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8DA;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="状态目录 (State Directory)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="保存 Tailscale 认证状态的文件夹，重启后保持登录。留空则使用默认位置" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBox Width="170" PlaceholderText="留空使用默认" Text="{x:Bind ViewModel.TailscaleStateDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Button x:Name="TailscaleStateDirBrowseButton" Style="{StaticResource SubtleButtonStyle}" Click="TailscaleStateDirBrowse_Click" ToolTipService.ToolTip="选择文件夹">
                                            <FontIcon Glyph="&#xE8DA;" FontSize="14"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Control URL -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="协调服务器 (Control URL)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="留空使用官方 Tailscale，或填入 Headscale 自建服务器地址" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center">
                                        <TextBox Width="220" PlaceholderText="留空 = 官方 Tailscale" Text="{x:Bind ViewModel.TailscaleControlUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Content="官方" Click="SetTailscaleControlUrlOfficial_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="清空" Click="ClearTailscaleControlUrl_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Ephemeral -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE81B;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="临时节点模式 (Ephemeral)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="断开后节点自动从 tailnet 中移除，适合临时或自动化部署场景" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.TailscaleEphemeral, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Accept Routes -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE909;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="接受其他节点路由 (Accept Routes)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="允许接收 tailnet 中其他节点通告的子网路由" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.TailscaleAcceptRoutes, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Advertise Routes -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xECAA;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="通告本地网段 (Advertise Routes)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="向 tailnet 共享本机所在网段，多个 CIDR 用逗号分隔，如 192.168.1.0/24" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="2" Width="220" PlaceholderText="192.168.1.0/24" Text="{x:Bind ViewModel.TailscaleAdvertiseRoutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Exit Node -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xF0AF;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="指定出口节点 (Exit Node)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="将全部出站流量通过指定的 tailnet 节点转发，填入对端节点 IP 或名称" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBox Grid.Column="2" Width="220" PlaceholderText="100.x.x.x 或留空" Text="{x:Bind ViewModel.TailscaleExitNode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Advertise Exit Node -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,4">
                                    <FontIcon Grid.Column="0" Glyph="&#xE72A;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="通告为出口节点 (Advertise Exit Node)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="将本机对外通告为 Exit Node，允许其他 tailnet 节点将流量经由本机出站" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.TailscaleAdvertiseExitNode, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- 使用提示 -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock Text="使用须知" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="• 首次启用且未填 Auth Key 时，请在日志页查看登录 URL 并用浏览器完成授权" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="• 已存在状态文件时，Auth Key 字段会被忽略，直接复用已认证状态" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="• sing-box 核心需支持 Tailscale（实验性功能，需 sing-box 1.12.0+）" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Panel: 路由分流 (Routing) -->
                    <StackPanel x:Name="RoutingPanel" Spacing="12" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <TextBlock Text="基础路由与隐私策略" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel>
                                <!-- Rule 1: Bypass CN -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE909;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="绕过中国大陆 (Bypass mainland China)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="对所有目标属于中国的 IP 或国内常见域名自动采用直连直达，不经过代理" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <Button x:Name="UpdateGeoButton" Style="{StaticResource SubtleButtonStyle}" Click="UpdateGeoButton_Click" ToolTipService.ToolTip="更新 Geo 路由数据文件 (geosite-cn.srs, geoip-cn.srs)">
                                            <FontIcon Glyph="&#xE895;" FontSize="16"/>
                                        </Button>
                                        <ToggleSwitch x:Name="SettingsBypassChinaSwitch" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.BypassChina, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Rule 2: Adblock -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE727;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="全局广告与隐私追踪拦截 (Block ads &amp; trackers)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="过滤并拦截来自内置规则源中的广告分发网站，保护隐私并节省带宽" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SettingsBlockAdsSwitch" Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.BlockAds, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Rule 3: Advanced Routing -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,4">
                                    <FontIcon Grid.Column="0" Glyph="&#xE8B1;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="启用高级分流模块 (Enable advanced routing module)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="开启后侧边栏将显示「分流规则」，允许配置各个应用策略及自定义域名、进程代理规则" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SettingsAdvancedRoutingSwitch" Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnableAdvancedRouting, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Panel: DNS 与解析 (DnsSettings) -->
                    <StackPanel x:Name="DnsSettingsPanel" Spacing="12" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>

                        <TextBlock Text="DNS 解析器配置" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel>
                                <!-- Direct DNS -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,4,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE753;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="直连 DNS (Direct)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="用于国内域名及直连出站的解析" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                        <TextBox Width="200" PlaceholderText="留空自动 (如 223.5.5.5)" Text="{x:Bind ViewModel.DirectDns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Content="阿里" Click="SetDirectDnsAli_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="腾讯" Click="SetDirectDnsTencent_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="114" Click="SetDirectDns114_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="DoH" Click="SetDirectDnsDoH_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Proxy DNS -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE72C;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="代理 DNS (Proxy)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="用于境外的域名解析，需通过代理出站以防止 DNS 污染" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                        <TextBox Width="200" PlaceholderText="如 https://1.1.1.1/dns-query" Text="{x:Bind ViewModel.ProxyDns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <Button Content="谷歌" Click="SetProxyDnsGoogle_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="CF" Click="SetProxyDnsCF_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="Quad9" Click="SetProxyDnsQuad9_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                            <Button Content="DoH" Click="SetProxyDnsDoH_Click" Padding="8,4" Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- Query Strategy -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE7B3;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="查询策略" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="决定 DNS 解析时 IP 版本的偏好" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2" Width="140" SelectedValue="{x:Bind ViewModel.DnsStrategy, Mode=TwoWay}" SelectedValuePath="Tag" VerticalAlignment="Center">
                                        <ComboBoxItem Content="仅 IPv4" Tag="ipv4_only"/>
                                        <ComboBoxItem Content="优先 IPv4" Tag="prefer_ipv4"/>
                                        <ComboBoxItem Content="优先 IPv6" Tag="prefer_ipv6"/>
                                        <ComboBoxItem Content="仅 IPv6" Tag="ipv6_only"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Enable Cache -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xEC4A;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="启用 DNS 缓存" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="大幅提升二次解析速度，降低延迟" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnableDnsCache, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- FakeDNS -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xF3B1;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="FakeDNS" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                            <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="4,2">
                                                <TextBlock Text="实验性" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="接管虚拟网卡 DNS，返回 198.18.x.x 假 IP 并拦截真实请求实现秒开" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.EnableFakeDns, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- IPv6 Route -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="拦截 IPv6 DNS 泄露 (Prevent IPv6 leak)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="在开启 TUN 模式时屏蔽 AAAA 查询，防止代理环境下的 IPV6 地理信息泄露" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SettingsBlockIPv6Switch" Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.BlockIPv6, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- TUN Stack -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <FontIcon Grid.Column="0" Glyph="&#xE839;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="TUN Stack" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="选择 TUN 入站使用的网络栈，mixed 为推荐默认值" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2" Width="160" SelectedValuePath="Tag" SelectedValue="{x:Bind ViewModel.TunStack, Mode=TwoWay}" VerticalAlignment="Center">
                                        <ComboBoxItem Content="mixed" Tag="mixed"/>
                                        <ComboBoxItem Content="system" Tag="system"/>
                                        <ComboBoxItem Content="gvisor" Tag="gvisor"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Flush DNS -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" HorizontalAlignment="Stretch" Padding="0,12,0,4">
                                    <FontIcon Grid.Column="0" Glyph="&#xE81E;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="静默刷新系统 DNS (Flush DNS cache)" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="切换节点或开启代理时，调用 Windows 原生 API 瞬间清除本地 DNS 缓存，防止网络不通" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="SettingsFlushDNSSwitch" Grid.Column="2" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.FlushDNS, Mode=TwoWay}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Panel 2: 协议色彩 -->
                    <StackPanel x:Name="ColorsPanel" Spacing="8" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                        
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Margin="0,0,0,8">
                            <StackPanel VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="节点协议标识" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="自定义各节点协议在卡片和列表中的颜色标签" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1" Click="ResetColorsButton_Click" Background="Transparent" BorderBrush="Transparent" Padding="8,6" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="重置颜色" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Border Background="Transparent" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" 
                                CornerRadius="8">
                            <StackPanel>
                                <!-- SS / Shadowsocks -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                        <PathIcon Foreground="{ThemeResource TextFillColorSecondaryBrush}" Data="M17,1.042 L11.436,14.954 L7.958,11.477 L8.653,13.563 L7.03,14.958 L7.03,11.563 L14.984,3.375 L6.047,9.969 L1,8.694 L17,1.042 Z" />
                                    </Viewbox>
                                    <TextBlock Grid.Column="1" Text="Shadowsocks / SS" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind SsColor, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind SsColor, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind SsColor, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <!-- VLESS -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <FontIcon Glyph="&#xE81E;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="VLESS" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind VlessColor, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind VlessColor, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind VlessColor, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <!-- VMess -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <FontIcon Glyph="&#xE909;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="VMess" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind VmessColor, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind VmessColor, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind VmessColor, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <!-- Hysteria 2 -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <FontIcon Glyph="&#xE945;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Hysteria 2" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind Hysteria2Color, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind Hysteria2Color, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind Hysteria2Color, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <!-- Trojan -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <FontIcon Glyph="&#xE12B;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Trojan" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind TrojanColor, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind TrojanColor, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind TrojanColor, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <!-- Fallback / Others -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="其他 / 未匹配协议" FontSize="14" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Width="24" Height="24" Padding="0" CornerRadius="12" VerticalAlignment="Center" Background="{x:Bind FallbackColor, Mode=OneWay, Converter={StaticResource ColorToBrushConverter}}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                                            <Button.Flyout>
                                                <Flyout Placement="Left">
                                                    <ColorPicker Color="{x:Bind FallbackColor, Mode=TwoWay}" IsAlphaEnabled="False" IsHexInputVisible="True" IsAlphaTextInputVisible="False" IsMoreButtonVisible="False"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <TextBlock Text="{x:Bind FallbackColor, Mode=OneWay, Converter={StaticResource ColorToHexStringConverter}}" FontSize="13" FontFamily="Consolas" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Panel 3: 开机与启动 -->
                    <StackPanel x:Name="AutostartPanel" Spacing="12" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                        
                        <TextBlock Text="系统启动行为" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="Windows 开机自启动" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="开启后，客户端将在系统登入时自动静默在托盘运行" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AutoStartSwitch" Grid.Column="1" VerticalAlignment="Center" OnContent="" OffContent="" MinWidth="0" IsOn="{x:Bind ViewModel.AutoStart, Mode=TwoWay}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- 本地代理端口设置 -->
                        <TextBlock Text="本地代理端口" FontSize="14" FontWeight="Medium" Margin="0,8,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel Spacing="4" VerticalAlignment="Center">
                                    <TextBlock Text="混合代理端口 (SOCKS5 &amp; HTTP)" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="sing-box 在本机监听的混合代理端口，SOCKS5 和 HTTP 共用同一端口。修改后将自动重启代理内核生效（范围 1024–65535）" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <NumberBox x:Name="MixedPortInput"
                                           Grid.Column="1"
                                           Width="110"
                                           Minimum="1024"
                                           Maximum="65535"
                                           SpinButtonPlacementMode="Inline"
                                           SmallChange="1"
                                           LargeChange="100"
                                           PlaceholderText="2080"
                                           Value="{x:Bind ViewModel.MixedPort, Mode=TwoWay}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Panel 4: 备份与恢复 -->
                    <StackPanel x:Name="BackupPanel" Spacing="12" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                        
                        <TextBlock Text="配置导出与导入" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                        <Border Background="Transparent" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" 
                                CornerRadius="8">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto" Padding="16,16" ColumnSpacing="16">
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="导出配置文件备份" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="将所有的本地自建节点、订阅链接以及色彩标识导出为备份 .zip 归档" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="ExportBackupButton" Grid.Column="1" Content="导出备份" Click="ExportBackupButton_Click" Padding="12,5" CornerRadius="4" VerticalAlignment="Center"/>
                                </Grid>

                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                <Grid ColumnDefinitions="*,Auto" Padding="16,16" ColumnSpacing="16">
                                    <StackPanel Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="导入配置文件恢复" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="⚠️ 此操作将完全覆盖当前所有的节点和参数，建议先做备份" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="ImportBackupButton" Grid.Column="1" Content="导入恢复" Click="ImportBackupButton_Click" Style="{StaticResource AccentButtonStyle}" Padding="12,5" CornerRadius="4" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Panel 5: 关于与内核 -->
                    <StackPanel x:Name="AboutPanel" Spacing="16" Visibility="Collapsed">
                        <StackPanel.ChildrenTransitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="28" />
                            </TransitionCollection>
                        </StackPanel.ChildrenTransitions>
                        
                        <!-- Top Info Card -->
                        <Border Background="Transparent" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="16,16">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                <StackPanel Spacing="6" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="Swell Proxy" FontSize="16" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                        <HyperlinkButton NavigateUri="https://github.com/yaog6700-bit/Swell-Proxy" ToolTipService.ToolTip="GitHub" Padding="6" CornerRadius="4" MinWidth="0" MinHeight="0" VerticalAlignment="Center">
                                            <Viewbox Width="16" Height="16">
                                                <PathIcon Data="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                                            </Viewbox>
                                        </HyperlinkButton>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.AppVersionText, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="(自适应 Fluent 原生版)" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Image Grid.Column="1" Source="ms-appx:///Assets/logo_about.png" Width="96" Height="96" VerticalAlignment="Center" Stretch="Uniform" />
                            </Grid>
                        </Border>

                        <StackPanel Spacing="12">
                            <TextBlock Text="内核与引导管理" FontSize="14" FontWeight="Medium" Margin="0,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                            <InfoBar IsOpen="{x:Bind MainViewModel.UpdateBadgeVisibility, Mode=OneWay, Converter={StaticResource VisibilityToBoolConverter}}"
                                     Severity="Success"
                                     Title="发现新版本"
                                     Message="{x:Bind MainViewModel.UpdateBannerText, Mode=OneWay}"
                                     IsClosable="False" />

                            <Border Background="Transparent" 
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" 
                                    CornerRadius="8">
                                <StackPanel>
                                    <!-- Core settings line -->
                                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,16" ColumnSpacing="12">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Sing-box Core 运行核心" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock x:Name="SingboxVersionText" Text="加载中..." FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="ReplaceCoreButton" Grid.Column="1" Padding="6" Background="Transparent" BorderBrush="Transparent" Click="ReplaceCoreButton_Click" ToolTipService.ToolTip="手动替换本地核心文件" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE8E5;" FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </Button>
                                        <Button x:Name="CheckUpdateButton" Grid.Column="2" Content="检查更新" Padding="12,5" CornerRadius="4" Click="CheckUpdateButton_Click" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="16,16" ColumnSpacing="12">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="客户端自动更新" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="检查是否有新版客户端发布" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="CheckAppUpdateButton" Grid.Column="2" Content="检查更新" Padding="12,5" CornerRadius="4" Click="CheckAppUpdateButton_Click" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="16,0"/>

                                    <!-- Reset Onboarding line -->
                                    <Grid ColumnDefinitions="*,Auto" Padding="16,16" ColumnSpacing="16">
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="重置新手引导" FontSize="14" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="清除已完成标记，下次启动应用时将再次显示新手引导" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="重置引导" Style="{StaticResource AccentButtonStyle}" Padding="12,5" CornerRadius="4" Click="ResetOnboardingButton_Click" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

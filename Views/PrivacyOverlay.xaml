<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="AnywhereWinUI.Views.PrivacyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="500"
             d:DesignHeight="600">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="24"
                    MaxWidth="360"
                    Padding="20">

            <Viewbox Width="64" Height="64" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE72E;" Foreground="{ThemeResource SystemFillColorCautionBrush}" />
            </Viewbox>

            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="隐私保护模式已开启"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="操作界面已锁定，请输入解锁密码以继续"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>

            <StackPanel Spacing="12">
                <PasswordBox x:Name="PasswordInput"
                             PlaceholderText="请输入解锁密码"
                             KeyUp="PasswordInput_KeyUp"
                             HorizontalAlignment="Stretch" />
                <TextBlock x:Name="ErrorText"
                           Text="密码错误，请重试"
                           Foreground="{StaticResource SystemFillColorCriticalBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Visibility="Collapsed" />
                <Button x:Name="UnlockButton"
                        Content="解锁"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Padding="0,8"
                        Click="UnlockButton_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>

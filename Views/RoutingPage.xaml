<Page
    x:Class="AnywhereWinUI.Views.RoutingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
            <TextBlock Text="分流规则" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="配置智能分流拦截规则，支持中国IP直连与全局广告净化" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Rules Management Card -->
        <Border Grid.Row="1"
                Background="Transparent"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24"
                MaxWidth="750"
                HorizontalAlignment="Left">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Action Toolbar -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                    <TextBlock Text="策略组配置" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="配置高级规则" Style="{ThemeResource AccentButtonStyle}" FontSize="12" Padding="14,6" CornerRadius="6" Click="AdvancedRulesButton_Click"/>
                </Grid>

                <ListView Grid.Row="1" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <!-- Google Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Google_Search.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Google / 谷歌服务" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 Google 搜索、Play 商店等指定节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleGoogleButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleGoogleEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleGoogleText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- Telegram Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Telegram / 电报" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 Telegram 的专用 IP 段指定节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleTelegramButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleTelegramEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleTelegramText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- Netflix Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Netflix.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Netflix / 奈飞" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 Netflix 指定一个原生解锁节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleNetflixButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleNetflixEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleNetflixText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- YouTube Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="YouTube / 油管" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 YouTube 视频指定高速节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleYouTubeButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleYouTubeEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleYouTubeText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- TikTok Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/TikTok.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="TikTok / 抖音国际版" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 TikTok 指定一个特定的免拔卡节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleTikTokButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleTikTokEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleTikTokText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- ChatGPT Rule -->
                    <ListViewItem Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/ChatGPT.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="ChatGPT / OpenAI" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 ChatGPT 服务指定一个原生解锁节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleChatGPTButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleChatGPTEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleChatGPTText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                    <!-- Claude Rule -->
                    <ListViewItem Padding="0,12">
                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch" Width="680">
                            <Image Grid.Column="0" Source="https://raw.githubusercontent.com/lige47/QuanX-icon-rule/main/icon/04ProxySoft/claude.png" Width="28" Height="28" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Claude / Anthropic" FontSize="14" FontWeight="Medium" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="为 Claude AI 指定一个原生纯净节点" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button x:Name="RuleClaudeButton" Grid.Column="2" VerticalAlignment="Center"
                                    CornerRadius="8" Padding="12,7" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon x:Name="RuleClaudeEmoji" Glyph="&#xE724;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="RuleClaudeText" Text="加载中..." FontSize="13" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE70D;" FontSize="9" Opacity="0.5" VerticalAlignment="Center" Margin="4,1,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </ListViewItem>

                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page
    x:Class="AnywhereWinUI.Views.ServersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:views="using:AnywhereWinUI.Views"
    xmlns:appcontrols="using:AnywhereWinUI.Controls"
    xmlns:services="using:AnywhereWinUI.Services"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="StateSuccessBrush" Color="#10B981" />
        <SolidColorBrush x:Key="StateErrorBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="StateNeutralBrush" Color="#6B7280" />
    </Page.Resources>

    <Grid x:Name="PageOuterGrid">
        <Grid x:Name="RootGrid" Margin="12,24,24,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar: Server List -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search & Filters -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <AutoSuggestBox x:Name="ServerSearchBox"
                                    Grid.Column="0"
                                    PlaceholderText="搜索服务器..."
                                    QueryIcon="Find"
                                    HorizontalAlignment="Stretch"
                                    TextMemberPath="Name"
                                    TextChanged="ServerSearchBox_TextChanged"
                                    SuggestionChosen="ServerSearchBox_SuggestionChosen"
                                    QuerySubmitted="ServerSearchBox_QuerySubmitted">
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="views:ServerEntryItem">
                                <Grid Padding="0,4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Grid.Row="1"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                        <TextBlock Text="{x:Bind HostPortDisplay, Mode=OneWay}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="·"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{x:Bind DisplayProtocol, Mode=OneWay}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>
                    <ToggleButton x:Name="GroupFilterToggleButton"
                                  Grid.Column="1"
                                  Background="Transparent"
                                  BorderBrush="Transparent"
                                  ToolTipService.ToolTip="筛选分组"
                                  Checked="GroupFilterToggleButton_Changed"
                                  Unchecked="GroupFilterToggleButton_Changed"
                                  Padding="6"
                                  VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8A9;" FontSize="16" />
                    </ToggleButton>
                </Grid>

                <Grid x:Name="GroupFilterBar"
                      Grid.Row="1"
                      Margin="0,12,0,0"
                      ColumnSpacing="8"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEA37;"
                                  FontSize="12"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="筛选条件:"
                                   FontSize="14"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <ComboBox x:Name="GroupFilterComboBox"
                              Grid.Column="1"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              SelectionChanged="GroupFilterComboBox_SelectionChanged" />

                    <DropDownButton x:Name="SortButton"
                                    Grid.Column="2"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    ToolTipService.ToolTip="排序">
                        <DropDownButton.Content>
                            <FontIcon Glyph="&#xE8CB;" FontSize="16" />
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:Name="SortDefaultItem"
                                                     Text="默认"
                                                     Tag="Default"
                                                     GroupName="ServerSortMode"
                                                     Click="SortMenuItem_Click" />
                                <RadioMenuFlyoutItem x:Name="SortActiveItem"
                                                     Text="当前连接"
                                                     Tag="Active"
                                                     GroupName="ServerSortMode"
                                                     Click="SortMenuItem_Click" />
                                <RadioMenuFlyoutItem x:Name="SortProtocolItem"
                                                     Text="协议"
                                                     Tag="Protocol"
                                                     GroupName="ServerSortMode"
                                                     Click="SortMenuItem_Click" />
                                <RadioMenuFlyoutItem x:Name="SortLatencyItem"
                                                     Text="延迟"
                                                     Tag="Latency"
                                                     GroupName="ServerSortMode"
                                                     Click="SortMenuItem_Click" />
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </Grid>
            </Grid>

            <!-- ListView of servers -->
            <ListView x:Name="ServersListView"
                      Grid.Row="1"
                      SelectionMode="Single"
                      SelectionChanged="ServersListView_SelectionChanged"
                      Background="Transparent"
                      Padding="0"
                      Margin="0"
                      HorizontalAlignment="Stretch"
                      CanReorderItems="True"
                      CanDragItems="True"
                      AllowDrop="True"
                      DragItemsCompleted="ServersListView_DragItemsCompleted">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,0"/>
                        <Setter Property="Margin" Value="0,0,0,2"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="views:ServerEntryItem">
                        <Grid Padding="0,6" 
                              DoubleTapped="ServerItem_DoubleTapped"
                              ContextRequested="ServerItem_ContextRequested"
                              Background="Transparent"
                              HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Active left border bar (Double line) -->
                            <StackPanel Grid.Column="0" 
                                        Orientation="Horizontal" 
                                        Spacing="3"
                                        Visibility="{x:Bind ActiveIndicatorVisibility, Mode=OneWay}"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center">
                                <Border Width="3" Height="24" CornerRadius="1.5" Background="{ThemeResource AccentFillColorDefaultBrush}" />
                                <Border Width="3" Height="14" CornerRadius="1.5" Background="{ThemeResource AccentFillColorDefaultBrush}" />
                            </StackPanel>

                            <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Top Row: Name on Left, Badges on Right -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE735;" 
                                                  FontSize="12" 
                                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                                  Visibility="{x:Bind FavoriteVisibility, Mode=OneWay}"
                                                  VerticalAlignment="Center" />
                                        <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                                Padding="8,2" CornerRadius="12"
                                                Visibility="{x:Bind ActiveIndicatorVisibility, Mode=OneWay}"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                <Ellipse Width="6" Height="6" Fill="White" VerticalAlignment="Center" />
                                                <TextBlock Text="已激活" FontSize="11" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Bottom Row: Host/Protocol on Left, Latency on Right -->
                                <Grid Grid.Row="1" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" MaxWidth="180">
                                            <Run Text="{x:Bind Host, Mode=OneWay}" />
                                            <Run Text=":" />
                                            <Run Text="{x:Bind Port, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="·" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{x:Bind DisplayProtocol, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="{x:Bind ProtocolBrush, Mode=OneWay}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" 
                                               Text="{x:Bind PingText, Mode=OneWay}"
                                               FontSize="10"
                                               Foreground="{x:Bind PingColor, Mode=OneWay}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Bottom Action Panel -->
            <Grid Grid.Row="2" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                    <Button Click="AddManualServer_Click"
                            ToolTipService.ToolTip="添加手动节点"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            Padding="8" CornerRadius="6">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon Glyph="&#xE710;" FontSize="16" />
                    </Button>
                    <Button Click="ImportFromClipboard_Click"
                            ToolTipService.ToolTip="从剪贴板导入节点/订阅"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            Padding="8" CornerRadius="6">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon Glyph="&#xE71B;" FontSize="16" />
                    </Button>
                    <Button Click="ManageSubscriptions_Click"
                            ToolTipService.ToolTip="订阅管理"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            Padding="8" CornerRadius="6">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon Glyph="&#xEBC3;" FontSize="16" />
                    </Button>
                    <Button x:Name="PingAllButton"
                            Click="PingAllServers_Click"
                            ToolTipService.ToolTip="一键测速"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            Padding="8" CornerRadius="6">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon Glyph="&#xEC4A;" FontSize="16" />
                    </Button>
                    <Button x:Name="QrShareButton"
                            Click="QrShareButton_Click"
                            ToolTipService.ToolTip="分享节点（二维码）"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            Padding="8" CornerRadius="6">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon Glyph="&#xED14;" FontSize="16" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Sidebar Divider (Removed) -->

        <!-- Right Content Area -->
        <Grid Grid.Column="2" Margin="24,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="1" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Panel 0: Empty/Default View -->
            <Grid x:Name="EmptyViewPanel" Grid.Row="0" Visibility="Visible" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xEC05;" FontSize="56" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="未选择服务器" Style="{ThemeResource SubtitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="从左侧列表中选择节点以查看详细配置参数、出口 IP 及 AI 解锁状态。" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" MaxWidth="300" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <!-- Panel 1: Detailed Server View -->
            <ScrollViewer x:Name="ServerDetailsPanel" Grid.Row="0" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <Grid Padding="20">
                    <StackPanel Spacing="20">
                        <!-- Title Bar Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="DetailTitle" Text="香港 VLESS-XTLS (Premium)" FontSize="20" FontWeight="Bold" />
                                <TextBlock x:Name="DetailSubtitle" Text="VLESS" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="DetailFavoriteButton"
                                          Grid.Column="1"
                                          Click="DetailFavoriteButton_Click"
                                          Padding="8" CornerRadius="18"
                                          VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE734;" FontSize="14" x:Name="DetailFavoriteIcon"/>
                            </ToggleButton>
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- Section: Connection Parameters -->
                        <Grid ColumnSpacing="24" RowSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Address -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="地址" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailHostText" Text="hk-vip.anywhere-server.com" FontWeight="Medium" VerticalAlignment="Center" />

                            <!-- Port -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailPortText" Text="443" FontWeight="Medium" VerticalAlignment="Center" />

                            <!-- Transport / Network -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="传输" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailNetworkText" Text="TCP" FontWeight="Medium" VerticalAlignment="Center" />

                            <!-- Latency -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="延迟" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock x:Name="DetailLatencyText" Text="--- ms" FontWeight="Bold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button x:Name="TestSingleLatencyButton" Click="TestSingleLatency_Click" Padding="4" Background="Transparent" BorderThickness="0" CornerRadius="4">
                                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </Grid>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- Section: AI Unlock Indicators -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="AI 解锁状态" FontSize="14" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="OpenAiLight" Width="8" Height="8" Fill="{StaticResource StateNeutralBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="OpenAI" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="ClaudeLight" Width="8" Height="8" Fill="{StaticResource StateNeutralBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="Claude" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse x:Name="GeminiLight" Width="8" Height="8" Fill="{StaticResource StateNeutralBrush}" VerticalAlignment="Center" />
                                    <TextBlock Text="Gemini" VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- Section: IP Network Status -->
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="IP 网络状态" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <ProgressRing x:Name="IpLoadingRing" IsActive="False" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            </Grid>
                            <Grid ColumnSpacing="16" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="70" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="出口 IP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock x:Name="IpAddressText" Text="-" FontWeight="Medium" VerticalAlignment="Center" />
                                    <Button Click="ToggleIpMask_Click" Padding="4" Background="Transparent" BorderThickness="0" CornerRadius="4">
                                        <FontIcon x:Name="IpMaskIcon" Glyph="&#xE890;" FontSize="14" />
                                    </Button>
                                    <Button Click="CopyIpStatus_Click" Padding="4" Background="Transparent" BorderThickness="0" CornerRadius="4">
                                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                    </Button>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="ISP 运营商" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="IpOrgText" Text="-" FontWeight="Medium" TextWrapping="Wrap" VerticalAlignment="Center" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="ASN 编号" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="IpAsnText" Text="-" FontWeight="Medium" VerticalAlignment="Center" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="地理位置" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="IpLocationText" Text="-" FontWeight="Medium" TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Panel 2: Edit/Add Manual Server Form -->
            <ScrollViewer x:Name="EditFormPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Stretch">
                    <TextBlock x:Name="EditFormTitle" Text="手动添加服务器" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>
                    <TextBlock Text="请在下方填写服务器配置参数。" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <TextBox x:Name="ServerNameInput" Header="节点名称" PlaceholderText="例如: 香港 BGP VLESS-XTLS" Margin="0,8,0,0"/>

                    <ComboBox x:Name="ServerProtocolInput" Header="协议类型" HorizontalAlignment="Stretch" SelectionChanged="ServerProtocolInput_SelectionChanged">
                        <ComboBoxItem Content="VLESS" IsSelected="True"/>
                        <ComboBoxItem Content="VMess"/>
                        <ComboBoxItem Content="Shadowsocks"/>
                        <ComboBoxItem Content="Trojan"/>
                        <ComboBoxItem Content="Hysteria 2"/>
                        <ComboBoxItem Content="TUIC"/>
                        <ComboBoxItem Content="NaiveProxy"/>
                        <ComboBoxItem Content="SOCKS"/>
                        <ComboBoxItem Content="AnyTLS"/>
                        <ComboBoxItem Content="HTTP"/>
                        <ComboBoxItem Content="WireGuard"/>
                        <ComboBoxItem Content="Snell"/>
                        <ComboBoxItem Content="Nowhere"/>
                    </ComboBox>

                    <!-- 前置代理 (Proxy Chain) -->
                    <ComboBox x:Name="ServerProxyChainInput" Header="前置代理 (Proxy Chain)" HorizontalAlignment="Stretch" />
                    <TextBlock Text="选择通过另一个代理服务器连接此节点（链式代理）" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,-8,0,0" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="ServerHostInput" Header="地址 / 域名" PlaceholderText="例如: hk.anywhere.com" />
                        <TextBox Grid.Column="1" x:Name="ServerPortInput" Header="端口" InputScope="Number" Text="443" />
                    </Grid>

                    <!-- Shadow-TLS settings -->
                    <StackPanel x:Name="ShadowTlsPanel" Spacing="12" Visibility="Collapsed">
                        <CheckBox x:Name="ServerIsShadowTlsInput" Content="启用 Shadow-TLS" Checked="ServerIsShadowTlsInput_Changed" Unchecked="ServerIsShadowTlsInput_Changed" />
                        <StackPanel x:Name="ShadowTlsSubPanel" Spacing="12" Visibility="Collapsed">
                            <ComboBox x:Name="ServerShadowTlsVersionInput" Header="Shadow-TLS 版本" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="3" IsSelected="True"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="1"/>
                            </ComboBox>
                            <TextBox x:Name="ServerShadowTlsPasswordInput" Header="Shadow-TLS 密码" PlaceholderText="请输入 Shadow-TLS 密码" />
                            <TextBox x:Name="ServerShadowTlsSniInput" Header="SNI（伪装域名）" PlaceholderText="例如: support.apple.com" />
                        </StackPanel>
                    </StackPanel>

                    <!-- 密码 / Token -->
                    <StackPanel x:Name="PasswordPanel" Spacing="8" Visibility="Collapsed">
                        <PasswordBox x:Name="ServerPasswordInput" Header="密码 / Token" PasswordChar="●" PlaceholderText="请输入密码或Token" />
                    </StackPanel>

                    <!-- WireGuard 设置 -->
                    <StackPanel x:Name="WireGuardPanel" Spacing="8" Visibility="Collapsed">
                        <TextBox x:Name="ServerWgPrivateKeyInput" Header="私钥 (Private Key)" PlaceholderText="请输入 WireGuard 私钥" />
                        <TextBox x:Name="ServerWgLocalAddressInput" Header="本地地址 (Local Address)" PlaceholderText="10.0.0.2/32" />
                        <TextBox x:Name="ServerWgPreSharedKeyInput" Header="预共享密钥 (Pre-Shared Key)" PlaceholderText="可选" />
                        <TextBox x:Name="ServerWgMtuInput" Header="MTU" InputScope="Number" PlaceholderText="1408 (为 0 则使用默认)" />
                    </StackPanel>

                    <!-- Nowhere 设置 -->
                    <StackPanel x:Name="NowherePanel" Spacing="8" Visibility="Collapsed">
                        <TextBox x:Name="ServerNowhereSpecInput" Header="Spec" PlaceholderText="请输入 Nowhere 的 Spec" />
                    </StackPanel>

                    <!-- Snell 设置 -->
                    <StackPanel x:Name="SnellPanel" Spacing="12" Visibility="Collapsed">
                        <PasswordBox x:Name="ServerSnellPskInput" Header="预共享密钥 (PSK)" PasswordChar="●" PlaceholderText="请输入 Snell PSK"/>
                        <ComboBox x:Name="ServerSnellVersionInput" Header="Snell 版本 (Version)" HorizontalAlignment="Stretch" SelectionChanged="ServerSnellVersionInput_SelectionChanged">
                            <ComboBoxItem Content="6"/>
                            <ComboBoxItem Content="4" IsSelected="True"/>
                            <ComboBoxItem Content="5"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="1"/>
                        </ComboBox>
                        <ComboBox x:Name="ServerSnellModeInput" Header="流量整形 (Mode) [仅 v6]" HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <ComboBoxItem Content="default" IsSelected="True"/>
                            <ComboBoxItem Content="unshaped"/>
                            <ComboBoxItem Content="unsafe-raw"/>
                        </ComboBox>
                        <ComboBox x:Name="ServerSnellObfsInput" Header="HTTP 混淆 (Obfs) [v1-v5]" HorizontalAlignment="Stretch" SelectionChanged="ServerSnellObfsInput_SelectionChanged">
                            <ComboBoxItem Content="关闭 (none)" IsSelected="True"/>
                            <ComboBoxItem Content="HTTP"/>
                        </ComboBox>
                        <TextBox x:Name="ServerSnellObfsHostInput" Header="混淆域名 (Obfs Host)" PlaceholderText="例如: bing.com" Visibility="Collapsed"/>
                    </StackPanel>

                    <!-- 混淆方式 (Obfs) -->
                    <StackPanel x:Name="ObfsPanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerObfsTypeInput" Header="混淆方式 (Obfs)" HorizontalAlignment="Stretch" SelectionChanged="ServerObfsTypeInput_SelectionChanged">
                            <ComboBoxItem Content="none" IsSelected="True" />
                            <ComboBoxItem Content="obfs" />
                        </ComboBox>
                        <TextBox x:Name="ServerObfsPasswordInput" Header="混淆密码 (Obfs Password)" PlaceholderText="请输入混淆密码" Visibility="Collapsed" />
                    </StackPanel>

                    <!-- UUID / 用户名 -->
                    <StackPanel x:Name="UuidPanel" Spacing="8" Visibility="Collapsed">
                        <TextBox x:Name="ServerUuidInput" Header="UUID" PlaceholderText="de000000-0000-0000-0000-000000000000" />
                    </StackPanel>

                    <!-- AlterID (VMess) -->
                    <StackPanel x:Name="AlterIdPanel" Spacing="8" Visibility="Collapsed">
                        <TextBox x:Name="ServerAlterIdInput" Header="AlterID" InputScope="Number" Text="0" />
                    </StackPanel>

                    <!-- 加密方式 -->
                    <StackPanel x:Name="EncryptionPanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerEncryptionInput" Header="加密方式" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <!-- 传输协议 (Network) -->
                    <StackPanel x:Name="NetworkPanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerNetworkInput" Header="传输协议 (Network)" HorizontalAlignment="Stretch" SelectionChanged="ServerNetworkInput_SelectionChanged">
                            <ComboBoxItem Content="tcp" IsSelected="True"/>
                            <ComboBoxItem Content="ws"/>
                            <ComboBoxItem Content="httpupgrade"/>
                            <ComboBoxItem Content="grpc"/>
                            <ComboBoxItem Content="xhttp"/>
                            <ComboBoxItem Content="kcp"/>
                            <ComboBoxItem Content="quic"/>
                            <ComboBoxItem Content="h2"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- 伪装类型 (Header Type) -->
                    <StackPanel x:Name="HeaderTypePanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerHeaderTypeInput" Header="伪装类型 (Header Type)" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="none" IsSelected="True" />
                            <ComboBoxItem Content="http" />
                        </ComboBox>
                    </StackPanel>

                    <!-- 路径与伪装 -->
                    <Grid x:Name="PathHostPanel" ColumnSpacing="12" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="ServerPathInput" Header="路径 (Path)" PlaceholderText="/v2ray" />
                        <TextBox Grid.Column="1" x:Name="ServerWsHostInput" Header="伪装域名 (Host)" PlaceholderText="example.com" />
                    </Grid>

                    <!-- 流控 (Flow) -->
                    <StackPanel x:Name="FlowPanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerFlowInput" Header="流控 (Flow)" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="none" IsSelected="True"/>
                            <ComboBoxItem Content="xtls-rprx-vision"/>
                            <ComboBoxItem Content="xtls-rprx-vision-udp443"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="SecurityPanel" Spacing="8" Visibility="Collapsed">
                        <ComboBox x:Name="ServerSecurityInput" Header="安全传输 (Security)" HorizontalAlignment="Stretch" SelectionChanged="ServerSecurityInput_SelectionChanged">
                            <ComboBoxItem Content="none" IsSelected="True"/>
                            <ComboBoxItem Content="tls"/>
                            <ComboBoxItem Content="reality"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- TLS 配置 -->
                    <StackPanel x:Name="TlsPanel" Spacing="12" Visibility="Collapsed">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="ServerSniInput" Header="SNI (Server Name Indication)" PlaceholderText="example.com" />
                            <ComboBox Grid.Column="1" x:Name="ServerFingerprintInput" Header="指纹 (Fingerprint)" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="none" IsSelected="True"/>
                                <ComboBoxItem Content="chrome"/>
                                <ComboBoxItem Content="firefox"/>
                                <ComboBoxItem Content="safari"/>
                                <ComboBoxItem Content="edge"/>
                                <ComboBoxItem Content="ios"/>
                                <ComboBoxItem Content="android"/>
                                <ComboBoxItem Content="random"/>
                                <ComboBoxItem Content="randomized"/>
                            </ComboBox>
                        </Grid>
                        <ComboBox x:Name="ServerAlpnInput" Header="ALPN" HorizontalAlignment="Stretch" IsEditable="True">
                            <ComboBoxItem Content="h2,http/1.1" />
                            <ComboBoxItem Content="h3" />
                            <ComboBoxItem Content="h3,h2,http/1.1" />
                        </ComboBox>
                        <CheckBox x:Name="ServerAllowInsecureInput" Content="允许不安全证书 (Allow Insecure)" />
                    </StackPanel>

                    <!-- Reality 专属 -->
                    <Grid x:Name="RealityPanel" ColumnSpacing="12" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="ServerPublicKeyInput" Header="PublicKey" PlaceholderText="PublicKey" />
                        <TextBox Grid.Column="1" x:Name="ServerShortIdInput" Header="ShortId" PlaceholderText="ShortId" />
                        <TextBox Grid.Column="2" x:Name="ServerSpiderXInput" Header="SpiderX" PlaceholderText="SpiderX" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,0">
                        <Button Content="保存" Click="SaveServer_Click" Style="{ThemeResource AccentButtonStyle}" Padding="20,10" CornerRadius="6"/>
                        <Button Content="取消" Click="CancelEdit_Click" Padding="20,10" CornerRadius="6"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Panel 3: Subscription Manager View -->
            <ScrollViewer x:Name="SubscriptionPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
                <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Stretch" Margin="0,0,0,24">
                    <TextBlock Text="订阅管理" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>
                    <TextBlock Text="支持批量导入和同步节点，方便快速更新。" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <controls:Segmented x:Name="SubSegmented" 
                                        HorizontalAlignment="Stretch" 
                                        SelectedIndex="0"
                                        SelectionChanged="SubSegmented_SelectionChanged"
                                        Margin="0,8,0,8">
                        <controls:SegmentedItem Content="添加新订阅"/>
                        <controls:SegmentedItem Content="我的订阅列表"/>
                    </controls:Segmented>

                    <!-- Tab 0: Import Subscription Form -->
                    <StackPanel x:Name="SubAddFormPanel" Spacing="16">
                        <TextBox x:Name="SubNameInput" Header="订阅名称" PlaceholderText="例如: GlaDOS VIP 订阅"/>
                        <TextBox x:Name="SubUrlInput" Header="订阅链接 (URL)" PlaceholderText="https://api.glados.space/subs/..."/>

                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                            <Button x:Name="SaveSubButton" Click="SaveSub_Click" Content="导入并同步" Style="{ThemeResource AccentButtonStyle}" Padding="20,10" CornerRadius="6"/>
                            <Button Content="返回" Click="CancelEdit_Click" Padding="20,10" CornerRadius="6"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Tab 1: Subscriptions Manager List -->
                    <StackPanel x:Name="SubListFormPanel" Visibility="Collapsed" Spacing="16">
                        <ListView x:Name="SubsListView" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="services:PersistedSubscription">
                                    <Grid Padding="0,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Sub Name -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        
                                        <!-- Sub URL -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Bind Url, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>

                                        <!-- Last Updated -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="4" Margin="0,6,0,0">
                                            <TextBlock Text="上次同步:" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="{x:Bind LastUpdated, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Actions -->
                                        <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Click="UpdateSub_Click" Padding="8" Margin="8,0,0,0" ToolTipService.ToolTip="同步">
                                            <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                        </Button>
                                        <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Click="DeleteSub_Click" Padding="8" Margin="4,0,0,0" Foreground="Red" ToolTipService.ToolTip="删除">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Button Content="返回" Click="CancelEdit_Click" Padding="20,10" CornerRadius="6" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Control Bar -->
            <Grid x:Name="BottomControlBar" Grid.Row="2" Margin="-24,12,0,0" Padding="24,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Bottom">
                    <ToggleButton x:Name="StartStopButton"
                                  Click="StartStopButton_Click"
                                  PointerEntered="Button_PointerEntered"
                                  PointerExited="Button_PointerExited"
                                  Width="56" Height="56"
                                  CornerRadius="28"
                                  Padding="0">
                        <ToggleButton.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </ToggleButton.ScaleTransition>
                        <FontIcon Glyph="&#xE7E8;" FontSize="24" />
                    </ToggleButton>

                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="ActiveNodeText" Text="未连接" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,2">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="↓" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock x:Name="DownSpeedText" Text="0.0 KB/s" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,0,0,0">
                            <TextBlock Text="↑" Foreground="{ThemeResource SystemAccentColor}" FontSize="12" VerticalAlignment="Center" />
                            <TextBlock x:Name="UpSpeedText" Text="0.0 KB/s" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="SessionUsageText" Text="0.0 MB" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                    <!-- 当面板隐藏但正在运行时显示此按钮 -->
                    <Button x:Name="ReopenTopSheetButton" 
                            Visibility="Collapsed"
                            Click="ReopenTopSheetButton_Click" 
                            Padding="8" CornerRadius="6"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            ToolTipService.ToolTip="查看实时面板">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <!-- 使用 ED1A 并且显式指定 FontFamily 防止变成黑块 -->
                        <FontIcon Glyph="&#xED1A;" FontSize="16" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                    </Button>

                    <!-- Proxy Mode -->
                    <Button x:Name="ProxyModeButton"
                            Padding="8" CornerRadius="6"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited"
                            ToolTipService.ToolTip="代理模式">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <!-- 默认系统代理为 MyNetwork -->
                        <FontIcon x:Name="ProxyModeIcon" Glyph="&#xEC27;" FontSize="16" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="系统代理" Tag="system" Click="SetProxyMode_Click" />
                                <MenuFlyoutItem Text="TUN模式" Tag="tun" Click="SetProxyMode_Click" />
                                <MenuFlyoutItem Text="仅手动代理" Tag="manual" Click="SetProxyMode_Click" />
                                <MenuFlyoutItem Text="TUN + 系统代理" Tag="tun-system" Click="SetProxyMode_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Routing Mode -->
                    <Button x:Name="RoutingModeButton"
                            Padding="8" CornerRadius="6"
                            PointerEntered="Button_PointerEntered"
                            PointerExited="Button_PointerExited">
                        <Button.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.15" />
                        </Button.ScaleTransition>
                        <FontIcon x:Name="RoutingModeIcon" Glyph="&#xE909;" FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="智能分流" Tag="smart" Click="SetRoutingMode_Click" />
                                <MenuFlyoutItem Text="全局路由" Tag="global" Click="SetRoutingMode_Click" />
                                <MenuFlyoutItem Text="直接连接" Tag="direct" Click="SetRoutingMode_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== QR Share Card Overlay ===== -->
        <Canvas x:Name="QrOverlayCanvas"
                Grid.Column="0" Grid.ColumnSpan="3"
                Visibility="Collapsed"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Canvas.ZIndex="99">

            <!-- Transparent dismiss hit area -->
            <Rectangle x:Name="QrDismissRect"
                       Width="4000" Height="4000"
                       Canvas.Left="-1000" Canvas.Top="-1000"
                       Fill="Transparent"
                       PointerPressed="QrDismissRect_PointerPressed"/>

            <!-- Popup card -->
            <Border x:Name="QrCardBorder"
                    Width="230"
                    CornerRadius="16"
                    Padding="20"
                    Translation="0,0,32"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="16">

                    <!-- QR code image in white frame -->
                    <Border Background="White"
                            CornerRadius="10"
                            Width="180" Height="180"
                            HorizontalAlignment="Center"
                            Padding="8">
                        <Image x:Name="QrCodeImage" Stretch="Uniform"/>
                    </Border>

                    <!-- Hint text -->
                    <TextBlock Text="使用手机/其它代理软件扫码导入"
                               FontSize="11"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>

                    <!-- Copy link button with gradient -->
                    <Button x:Name="CopyLinkButton"
                            HorizontalAlignment="Stretch"
                            CornerRadius="8"
                            Padding="0,10"
                            BorderThickness="0"
                            Click="CopyLinkButton_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <TextBlock x:Name="CopyLinkButtonText"
                                   Text="复制分享链接"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Button>

                </StackPanel>
            </Border>
        </Canvas>

        </Grid>

        <!-- Top Sheet Overlay (Hidden by default using Translation.Y = -1000) -->
        <Grid x:Name="TopSheetOverlay" 
              Visibility="Collapsed" 
              CornerRadius="0,0,16,16"
              Height="400"
              VerticalAlignment="Top"
              Margin="0,0,0,0"
              BorderThickness="0,0,0,1"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            
            <!-- 高级亚克力毛玻璃背景 -->
            <Grid.Background>
                <ThemeResource ResourceKey="AcrylicBackgroundFillColorDefaultBrush" />
            </Grid.Background>

            <!-- 增加大阴影，使其看起来更像浮在上面 -->
            <Grid.Shadow>
                <ThemeShadow />
            </Grid.Shadow>

            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE7E8;" FontSize="24" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="概览" Style="{ThemeResource TitleTextBlockStyle}" />
                    </StackPanel>
                    <Button Grid.Column="1" Click="CloseTopSheet_Click" Background="Transparent" BorderThickness="0" CornerRadius="20" Width="40" Height="40" Padding="0">
                        <FontIcon Glyph="&#xE711;" FontSize="14" />
                    </Button>
                </Grid>

                <!-- Mock Content Body -->
                <StackPanel Grid.Row="1" Spacing="24" Margin="0,24,0,0">
                    <Grid ColumnSpacing="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Mock Stats -->
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="当前节点" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TopSheetNodeNameText" Text="---" FontWeight="Bold" FontSize="16" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="运行时间" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TopSheetUptimeText" Text="00:00:00" FontWeight="Bold" FontSize="16" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="网络延迟" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="TopSheetLatencyText" Text="--- ms" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="Bold" FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <!-- Mock Chart Area -->
                    <Border Background="Transparent" 
                            CornerRadius="8" 
                            Height="160" 
                            BorderThickness="0" 
                            Padding="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 实时速度文本 -->
                            <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center" Margin="0,0,16,0">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="下载" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="TopSheetDownText" Text="0 B/s" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="上传" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="TopSheetUpText" Text="0 B/s" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Win2D 真实走势图控件 -->
                            <appcontrols:Win2DTrafficChart x:Name="TopSheetMockChart" Grid.Column="1" />
                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </Grid>
    </Grid>
</Page>

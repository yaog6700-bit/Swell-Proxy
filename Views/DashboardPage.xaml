<Page
    x:Class="AnywhereWinUI.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tk="using:CommunityToolkit.WinUI.Controls"
    xmlns:controls="using:AnywhereWinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <!-- Icon background tints (semi-transparent) -->
        <SolidColorBrush x:Key="UploadIconBg"   Color="#2034D399"/>
        <SolidColorBrush x:Key="DownloadIconBg" Color="#2060A5FA"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- InfoBar -->
            <RowDefinition Height="*"/>     <!-- Scrollable Content -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="4">
            <TextBlock Text="控制台"
                       FontSize="24" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="简洁现代的网络代理管理器"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- ── Status InfoBar (connection events) ── -->
        <InfoBar x:Name="StatusInfoBar"
                 Grid.Row="1"
                 IsOpen="False"
                 IsClosable="True"
                 Margin="0,0,0,12"/>

        <!-- ── Main Scrollable Content ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" Padding="0,0,0,24">

                <!-- ════════════════════════════════════════════
                     Hero Card — Full-width core status card
                     ════════════════════════════════════════════ -->
                <Border x:Name="HeroCard"
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="28,24">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top Section: Button, Name, Latency -->
                        <Grid Grid.Row="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Row 0: Toggle, Node Name, Latency -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>  <!-- Toggle button -->
                                    <ColumnDefinition Width="*"/>     <!-- Node name + status -->
                                    <ColumnDefinition Width="Auto"/>  <!-- Latency + IP -->
                                </Grid.ColumnDefinitions>

                                <!-- Circular Power Toggle Button -->
                                <ToggleButton x:Name="CoreToggleBtn"
                                              Grid.Column="0"
                                              IsChecked="{x:Bind ViewModel.IsCoreRunning, Mode=TwoWay}"
                                              Command="{x:Bind ViewModel.ToggleCoreCommand}"
                                              Width="64" Height="64"
                                              CornerRadius="32"
                                              Padding="0"
                                              VerticalAlignment="Center">
                                    <!-- Override Checked-state colors to use Accent color -->
                                    <ToggleButton.Resources>
                                        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked"
                                                         Color="{ThemeResource SystemAccentColor}"/>
                                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver"
                                                         Color="{ThemeResource SystemAccentColorLight1}"/>
                                        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed"
                                                         Color="{ThemeResource SystemAccentColorDark1}"/>
                                        <SolidColorBrush x:Key="ToggleButtonForegroundChecked"
                                                         Color="White"/>
                                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver"
                                                         Color="White"/>
                                        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed"
                                                         Color="White"/>
                                    </ToggleButton.Resources>
                                    <FontIcon Glyph="&#xE7E8;" FontSize="28"/>
                                </ToggleButton>

                        <!-- Node Name + Status -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="20,0,20,0"
                                    Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse x:Name="HeroStatusDot"
                                         Width="8" Height="8"
                                         Fill="{ThemeResource TextFillColorTertiaryBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.CoreStatusText, Mode=OneWay}"
                                           FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.CurrentNodeName, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="点击左侧按钮切换引擎状态"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>

                        <!-- Latency + IP (right side) -->
                        <Grid Grid.Column="2" VerticalAlignment="Center" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                                <!-- Latency with ContentThemeTransition -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="延迟:"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                    <ContentControl Content="{x:Bind ViewModel.CurrentLatency, Mode=OneWay}"
                                                    FontWeight="SemiBold" FontSize="13"
                                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                                    VerticalAlignment="Center">
                                        <ContentControl.ContentTransitions>
                                            <TransitionCollection>
                                                <ContentThemeTransition HorizontalOffset="0" VerticalOffset="-6"/>
                                            </TransitionCollection>
                                        </ContentControl.ContentTransitions>
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate><TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="13"/></DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                </StackPanel>
                                <!-- IP with ContentThemeTransition -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="IP:"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                    <ContentControl Content="{x:Bind ViewModel.CurrentIp, Mode=OneWay}"
                                                    FontWeight="SemiBold" FontSize="13"
                                                    VerticalAlignment="Center">
                                        <ContentControl.ContentTransitions>
                                            <TransitionCollection>
                                                <ContentThemeTransition HorizontalOffset="0" VerticalOffset="-6"/>
                                            </TransitionCollection>
                                        </ContentControl.ContentTransitions>
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate><TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="13"/></DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                </StackPanel>
                            </Grid>
                            </Grid>

                            <!-- Row 1: Routing Mode -->
                            <StackPanel Grid.Row="1" Margin="0,24,0,0" HorizontalAlignment="Left" Width="360">
                                <TextBlock Text="路由模式" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="13" Margin="0,0,0,8" FontWeight="SemiBold"/>
                                <tk:Segmented SelectedIndex="{x:Bind ViewModel.SelectedModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <tk:SegmentedItem Content="规则 (Rule)" />
                                    <tk:SegmentedItem Content="全局 (Global)" />
                                    <tk:SegmentedItem Content="直连 (Direct)" />
                                </tk:Segmented>
                            </StackPanel>

                        </Grid>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════════════
                     Row 2 — Traffic Chart  |  Route + Proxy Mode
                     ════════════════════════════════════════════ -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Traffic Chart Card -->
                    <Border x:Name="TrafficCard"
                            Grid.Column="0"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Speed header row -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <Border Background="{StaticResource UploadIconBg}"
                                            CornerRadius="6" Padding="6">
                                        <FontIcon Glyph="&#xE898;" FontSize="14" Foreground="#34D399"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="上传速度" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <!-- Upload speed with ContentThemeTransition -->
                                        <ContentControl Content="{x:Bind ViewModel.UploadSpeed, Mode=OneWay}"
                                                        FontSize="14" FontWeight="Bold">
                                            <ContentControl.ContentTransitions>
                                                <TransitionCollection>
                                                    <ContentThemeTransition HorizontalOffset="0" VerticalOffset="-4"/>
                                                </TransitionCollection>
                                            </ContentControl.ContentTransitions>
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate><TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold"/></DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Border Background="{StaticResource DownloadIconBg}"
                                            CornerRadius="6" Padding="6">
                                        <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="#60A5FA"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="下载速度" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <!-- Download speed with ContentThemeTransition -->
                                        <ContentControl Content="{x:Bind ViewModel.DownloadSpeed, Mode=OneWay}"
                                                        FontSize="14" FontWeight="Bold">
                                            <ContentControl.ContentTransitions>
                                                <TransitionCollection>
                                                    <ContentThemeTransition HorizontalOffset="0" VerticalOffset="-4"/>
                                                </TransitionCollection>
                                            </ContentControl.ContentTransitions>
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate><TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold"/></DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Win2D animated chart -->
                            <!-- Clip height is generous (500) so the 2px stroke at y=canvas-height
                                 is never cut off; the left/right -20 margins need the clip. -->
                            <Grid Grid.Row="1" Height="120" Margin="-20,0,-20,-20">
                                <Grid.Clip>
                                    <RectangleGeometry Rect="0,0,2000,500"/>
                                </Grid.Clip>
                                <controls:Win2DTrafficChart
                                    UploadTraffic="{x:Bind ViewModel.UploadTraffic, Mode=OneWay}"
                                    DownloadTraffic="{x:Bind ViewModel.DownloadTraffic, Mode=OneWay}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ════════════════════════════════════════════
                     Row 3 — Subscription Info  |  Quick Actions
                     ════════════════════════════════════════════ -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Subscription Info Card -->
                    <Border x:Name="SubCard"
                            Grid.Column="0"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8F1;" FontSize="16"
                                          Foreground="{ThemeResource SystemAccentColor}"/>
                                <TextBlock Text="订阅信息" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Used Traffic label + percentage -->
                            <Grid>
                                <TextBlock Text="已用流量" HorizontalAlignment="Left"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.SubUsedPercent, Mode=OneWay}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>

                            <!-- Color-coded progress bar -->
                            <ProgressBar Value="{x:Bind ViewModel.SubProgress, Mode=OneWay}"
                                         Maximum="100" Height="8" CornerRadius="4"
                                         Foreground="{x:Bind ViewModel.SubProgressBrush, Mode=OneWay}"/>

                            <!-- Used / Total detail -->
                            <Grid>
                                <TextBlock Text="{x:Bind ViewModel.SubUsed, Mode=OneWay}"
                                           HorizontalAlignment="Left"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           FontSize="11"/>
                                <TextBlock Text="{x:Bind ViewModel.SubTotal, Mode=OneWay}"
                                           HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           FontSize="11"/>
                            </Grid>

                            <!-- Remaining days -->
                            <Grid>
                                <TextBlock Text="剩余时长" HorizontalAlignment="Left"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.SubRemainingDays, Mode=OneWay}"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Quick Actions Card -->
                    <Border x:Name="ActionCard"
                            Grid.Column="1"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE713;" FontSize="16"
                                          Foreground="{ThemeResource SystemAccentColor}"/>
                                <TextBlock Text="快捷操作" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Proxy Mode -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="代理模式" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <tk:Segmented SelectedIndex="{x:Bind ViewModel.ProxyModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <tk:SegmentedItem Content="系统代理"/>
                                    <tk:SegmentedItem Content="TUN 模式"/>
                                </tk:Segmented>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <Button Command="{x:Bind ViewModel.RefreshSubCommand}"
                                    HorizontalAlignment="Stretch"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                        <TextBlock Text="更新所有订阅"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

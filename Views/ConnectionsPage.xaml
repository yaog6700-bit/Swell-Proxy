<Page
    x:Class="AnywhereWinUI.Views.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:AnywhereWinUI.Models"
    xmlns:mycontrols="using:AnywhereWinUI.Controls"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
            <TextBlock Text="活动连接" FontSize="20" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
            <TextBlock Text="实时监控并分析经过本地代理引擎的所有网络请求" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Command="{x:Bind ViewModel.ToggleCaptureCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{x:Bind ViewModel.CaptureButtonIcon, Mode=OneWay}" FontSize="14" Foreground="{ThemeResource SystemAccentColorLight2}"/>
                        <TextBlock Text="{x:Bind ViewModel.CaptureButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.ClearConnectionsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="清空" />
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <AutoSuggestBox Grid.Column="2" Width="240" 
                            PlaceholderText="搜索域名或 IP..." 
                            QueryIcon="Find" 
                            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                            TextChanged="AutoSuggestBox_TextChanged"/>
        </Grid>

        <!-- Topology Graph (Row 2) -->
        <Border Grid.Row="2" Margin="0,0,0,16" Background="Transparent" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xF6FA;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}"/>
                    <TextBlock Text="连接拓扑" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
                <mycontrols:TopologyGraphControl Height="280" Margin="-20,0,-20,-20" />
            </StackPanel>
        </Border>

        <!-- Connections List -->
        <Border Grid.Row="3"
                Background="Transparent" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" 
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Custom Header -->
                <Grid Grid.Row="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="12,0" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="类型" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="目标主机" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="状态" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="出站节点" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="规则" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="耗时" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="大小" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </Grid>

                <ListView Grid.Row="1" 
                          ItemsSource="{x:Bind ViewModel.Connections, Mode=OneWay}"
                          SelectionMode="Single"
                          ShowsScrollingPlaceholders="False"
                          Padding="0,4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="MinHeight" Value="40" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ConnectionItem">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>

                                <!-- Type Badge -->
                                <Border Grid.Column="0" 
                                        Background="{x:Bind BadgeBackground}"
                                        CornerRadius="4" 
                                        HorizontalAlignment="Left" 
                                        VerticalAlignment="Center" 
                                        Padding="6,2">
                                    <TextBlock Text="{x:Bind Type}" 
                                               Foreground="{x:Bind BadgeForeground}" 
                                               FontSize="11" 
                                               FontWeight="SemiBold" 
                                               FontFamily="Consolas" />
                                </Border>

                                <!-- Host -->
                                <TextBlock Grid.Column="1" Text="{x:Bind Host}" TextTrimming="CharacterEllipsis" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <!-- Status -->
                                <TextBlock Grid.Column="2" Text="{x:Bind Status}" Foreground="{x:Bind StatusForeground}" FontSize="12" VerticalAlignment="Center"/>

                                <!-- Node -->
                                <TextBlock Grid.Column="3" Text="{x:Bind Node}" TextTrimming="CharacterEllipsis" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <!-- Rule -->
                                <TextBlock Grid.Column="4" Text="{x:Bind Rule}" TextTrimming="CharacterEllipsis" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                <!-- Duration -->
                                <TextBlock Grid.Column="5" Text="{x:Bind Duration}" FontSize="12" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>

                                <!-- Size -->
                                <TextBlock Grid.Column="6" Text="{x:Bind Size}" FontSize="12" FontFamily="Consolas" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>

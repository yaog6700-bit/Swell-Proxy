<Application
    x:Class="AnywhereWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AnywhereWinUI"
    xmlns:converters="using:AnywhereWinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Custom styling and colors can go here -->
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#B3FFFFFF" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#80FFFFFF" />
                    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#99FFFFFF" />
                    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#80FFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush" Color="#80202020" />
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#66101010" />
                    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="#66303030" />
                    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="#50202020" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:ColorToBrushConverter x:Key="ColorToBrushConverter" />
            <converters:ColorToHexStringConverter x:Key="ColorToHexStringConverter" />
            <converters:ProtocolToBrushConverter x:Key="ProtocolToBrushConverter" />
            <converters:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

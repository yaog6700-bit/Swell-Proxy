<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AnywhereWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:AnywhereWinUI.Views"
    mc:Ignorable="d"
    Title="Swell Proxy">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- Temporary overlay for theme transition animation (placed behind ContentWrapper in Z-order) -->
        <Grid x:Name="ThemeTransitionOverlay" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border x:Name="ThemeTransitionBackground" />
            <Image x:Name="ThemeTransitionImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" />
        </Grid>

        <!-- ContentWrapper: clip animation targets this to cover both nav pane AND content area -->
        <Grid x:Name="ContentWrapper" Visibility="{x:Bind ViewModel.MainContentVisibility, Mode=OneWay}">
            <Grid x:Name="FullModeGrid">
            <NavigationView x:Name="MainNav"
                            PaneDisplayMode="LeftMinimal"
                            IsPaneOpen="False"
                            OpenPaneLength="240"
                            IsBackButtonVisible="Collapsed"
                            IsSettingsVisible="False"
                            AlwaysShowHeader="False"
                            Header=""
                            Margin="0,0,0,0"
                            Background="Transparent">
                <NavigationView.PaneHeader>
                    <Grid Height="32" />
                </NavigationView.PaneHeader>
                <NavigationView.Resources>
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="NavigationViewContentGridBorderBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="NavigationViewContentGridBackground" Color="Transparent" />
                </NavigationView.Resources>
                <NavigationView.MenuItems>
                    <NavigationViewItem x:Name="DashboardNavItem" 
                                        Content="仪表盘" 
                                        Tag="dashboard" 
                                        ToolTipService.ToolTip="仪表盘"
                                        PointerEntered="DashboardNavItem_PointerEntered" 
                                        PointerExited="DashboardNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <FontIcon x:Name="DashboardNavIcon" Glyph="&#xE80F;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="ServersNavItem" 
                                        Content="服务器" 
                                        Tag="servers" 
                                        ToolTipService.ToolTip="服务器节点"
                                        PointerEntered="ServersNavItem_PointerEntered" 
                                        PointerExited="ServersNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <FontIcon x:Name="ServersNavIcon" Glyph="&#xE128;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="RoutingNavItem" 
                                        Content="分流规则" 
                                        Tag="routing" 
                                        ToolTipService.ToolTip="分流规则"
                                        PointerEntered="RoutingNavItem_PointerEntered" 
                                        PointerExited="RoutingNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <FontIcon x:Name="RoutingNavIcon" Glyph="&#xE8B1;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="TrafficNavItem" 
                                        Content="流量与数据" 
                                        Tag="traffic" 
                                        ToolTipService.ToolTip="流量与数据"
                                        PointerEntered="TrafficNavItem_PointerEntered" 
                                        PointerExited="TrafficNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <ImageIcon x:Name="TrafficNavIcon" Source="ms-appx:///Assets/nav_traffic.png" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="ConnectionsNavItem" 
                                        Content="活动连接" 
                                        Tag="connections" 
                                        ToolTipService.ToolTip="活动连接"
                                        PointerEntered="ConnectionsNavItem_PointerEntered" 
                                        PointerExited="ConnectionsNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <PathIcon x:Name="ConnectionsNavIcon" Data="M9 7C9.55228 7 10 7.44772 10 8C10 8.51284 9.61396 8.93551 9.11662 8.99327L9 9H7C5.34315 9 4 10.3431 4 12C4 13.5977 5.24892 14.9037 6.82373 14.9949L7 15H9C9.55228 15 10 15.4477 10 16C10 16.5128 9.61396 16.9355 9.11662 16.9933L9 17H7C4.23858 17 2 14.7614 2 12C2 9.31125 4.12231 7.11818 6.78311 7.00462L7 7H9ZM17 7C19.7614 7 22 9.23858 22 12C22 14.6888 19.8777 16.8818 17.2169 16.9954L17 17H15C14.4477 17 14 16.5523 14 16C14 15.4872 14.386 15.0645 14.8834 15.0067L15 15H17C18.6569 15 20 13.6569 20 12C20 10.4023 18.7511 9.09634 17.1763 9.00509L17 9H15C14.4477 9 14 8.55228 14 8C14 7.48716 14.386 7.06449 14.8834 7.00673L15 7H17ZM7 11H17C17.5523 11 18 11.4477 18 12C18 12.5128 17.614 12.9355 17.1166 12.9933L17 13H7C6.44772 13 6 12.5523 6 12C6 11.4872 6.38604 11.0645 6.88338 11.0067L7 11H17H7Z"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="LogsNavItem" 
                                        Content="请求日志" 
                                        Tag="logs" 
                                        ToolTipService.ToolTip="请求日志"
                                        PointerEntered="LogsNavItem_PointerEntered" 
                                        PointerExited="LogsNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <PathIcon x:Name="LogsNavIcon" Data="M15.9862 3.99944C15.8616 2.87472 14.9079 2 13.75 2H10.25C9.09205 2 8.13841 2.87472 8.01379 3.99944L6.25 4C5.00736 4 4 5.00736 4 6.25V19.75C4 20.9926 5.00736 22 6.25 22H11.0014C10.9942 21.8075 11.0139 21.6088 11.0642 21.4075L11.2911 20.5H6.25C5.83579 20.5 5.5 20.1642 5.5 19.75V6.25C5.5 5.83579 5.83579 5.5 6.25 5.5L8.37902 5.5002C8.78267 6.1031 9.46997 6.5 10.25 6.5H13.75C14.53 6.5 15.2174 6.10307 15.621 5.50016L17.75 5.5C18.1642 5.5 18.5 5.83579 18.5 6.25V11.8606C18.9371 11.4604 19.4561 11.1998 20 11.0788V6.25C20 5.00736 18.9926 4 17.75 4L15.9862 3.99944ZM15.9948 4.09595L16 4.25C16 4.19822 15.9983 4.14685 15.9948 4.09595ZM10.25 3.5H13.75C14.1642 3.5 14.5 3.83579 14.5 4.25C14.5 4.66421 14.1642 5 13.75 5H10.25C9.83579 5 9.5 4.66421 9.5 4.25C9.5 3.83579 9.83579 3.5 10.25 3.5ZM13.356 17H8C7.58579 17 7.25 17.3358 7.25 17.75C7.25 18.1642 7.58579 18.5 8 18.5H11.983C12.1278 18.2712 12.298 18.058 12.4912 17.8648L13.356 17ZM12 14.5H8C7.58579 14.5 7.25 14.1642 7.25 13.75C7.25 13.3358 7.58579 13 8 13H12C12.4142 13 12.75 13.3358 12.75 13.75C12.75 14.1642 12.4142 14.5 12 14.5ZM16 10.5H8C7.58579 10.5 7.25 10.1642 7.25 9.75C7.25 9.33579 7.58579 9 8 9H16C16.4142 9 16.75 9.33579 16.75 9.75C16.75 10.1642 16.4142 10.5 16 10.5ZM19.0999 12.6695L13.1974 18.5719C12.8533 18.916 12.6092 19.3472 12.4911 19.8194L12.0334 21.6501C11.8344 22.4462 12.5556 23.1674 13.3517 22.9683L15.1824 22.5106C15.6545 22.3926 16.0857 22.1485 16.4299 21.8043L22.3323 15.9019C23.2249 15.0093 23.2249 13.5621 22.3323 12.6695C21.4397 11.7768 19.9925 11.7768 19.0999 12.6695Z"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItem x:Name="PluginsNavItem" 
                                        Content="插件" 
                                        Tag="plugins" 
                                        ToolTipService.ToolTip="JS 插件管理">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xECAA;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>

                    <NavigationViewItemSeparator/>

                    <NavigationViewItem x:Name="SettingsNavItem" 
                                        Content="设置" 
                                        Tag="settings" 
                                        ToolTipService.ToolTip="应用设置"
                                        PointerEntered="SettingsNavItem_PointerEntered" 
                                        PointerExited="SettingsNavItem_PointerExited">
                        <NavigationViewItem.Icon>
                            <FontIcon x:Name="SettingsNavIcon" Glyph="&#xE713;" />
                        </NavigationViewItem.Icon>
                        <NavigationViewItem.InfoBadge>
                            <InfoBadge x:Name="UpdateBadge" Style="{ThemeResource AttentionIconInfoBadgeStyle}" Visibility="{x:Bind ViewModel.UpdateBadgeVisibility, Mode=OneWay}" />
                        </NavigationViewItem.InfoBadge>
                    </NavigationViewItem>
                </NavigationView.MenuItems>

                <!-- CacheSize keeps recently visited pages alive with NavigationCacheMode on each Page -->
                <Frame x:Name="ContentFrame" Margin="0,48,0,0" CacheSize="10"/>
            </NavigationView>

            <StackPanel x:Name="LogoStackPanel" Orientation="Horizontal" VerticalAlignment="Top" Margin="48,0,0,0" Height="48" Spacing="8" HorizontalAlignment="Left" IsHitTestVisible="False">
                <Image x:Name="TitleBarLogo" Source="ms-appx:///Assets/output_grey.ico" Width="18" Height="18" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBlock Text="Swell Proxy" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Custom Title Bar Area for dragging, placed in the remaining empty space (X = 240 to Width - 140) -->
            <Grid x:Name="AppTitleBar" Height="48" Background="Transparent" VerticalAlignment="Top" Margin="240,0,140,0"/>

            <!-- Mini Mode Toggle Button: aligned to the left of the 240px navigation drawer (x=48) -->
            <Button x:Name="MiniModeToggleButton"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Width="36" Height="36"
                    Margin="48,6,0,0"
                    CornerRadius="4"
                    Visibility="Collapsed"
                    Background="Transparent" BorderBrush="Transparent"
                    Padding="0"
                    Tapped="MiniModeToggleButton_Tapped" ToolTipService.ToolTip="切换迷你窗口">
                <FontIcon Glyph="&#xEA49;" FontSize="16"/>
            </Button>

            <!-- Theme Toggle Button: aligned to the right side of the 240px navigation drawer (x=180, width=48) -->
            <Button x:Name="ThemeToggleButton"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Width="36" Height="36"
                    Margin="192,6,0,0"
                    CornerRadius="4"
                    Visibility="Collapsed"
                    Background="Transparent" BorderBrush="Transparent"
                    Padding="0"
                    Click="ThemeToggleButton_Click" ToolTipService.ToolTip="切换主题">
                <FontIcon x:Name="ThemeToggleIcon" Glyph="&#xE706;" FontSize="18"/>
            </Button>
            </Grid>

            <!-- Mini Mode Grid -->
            <Grid x:Name="MiniModeGrid" Visibility="Collapsed" Margin="16,0,16,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="2,18,20,0" VerticalAlignment="Top" Spacing="2">
                        <TextBlock x:Name="MiniServerNameText" Text="未选择节点" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxWidth="150" HorizontalAlignment="Left" />
                        <TextBlock x:Name="MiniProxyModeText" Text="智能分流" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ToggleButton x:Name="MiniStartStopButton" Click="MiniStartStopButton_Click" Width="40" Height="40" CornerRadius="20" Padding="0" BorderThickness="0" VerticalAlignment="Bottom">
                            <FontIcon Glyph="&#xE7E8;" FontSize="16" />
                        </ToggleButton>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <Ellipse x:Name="MiniStatusDot" Width="6" Height="6" Fill="Gray" VerticalAlignment="Center" />
                            <TextBlock x:Name="MiniStatusText" Text="未连接" FontSize="13" FontWeight="Medium" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Grid>

                <Border x:Name="MiniDragRegion" Height="32" Margin="0,0,56,0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Background="Transparent" />

                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,-10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="MiniExpandButton" Grid.Column="0" Width="28" Height="22" Padding="0" BorderThickness="0" Background="Transparent" ToolTipService.ToolTip="展开" Click="MiniExpandButton_Click">
                        <FontIcon Glyph="&#xE740;" FontSize="12" />
                    </Button>
                    <Button x:Name="MinicloseButton" Grid.Column="1" Width="28" Height="22" Padding="0" BorderThickness="0" Background="Transparent" ToolTipService.ToolTip="隐藏到托盘" Click="MinicloseButton_Click">
                        <FontIcon Glyph="&#xE711;" FontSize="12" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- 新手引导遮罩层：懒加载，首次需要时才由代码注入 OnboardingControl 实例 -->
        <ContentControl x:Name="AppOnboardingHost" Visibility="Collapsed" Canvas.ZIndex="100"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
                        
        <!-- 隐私保护模式遮罩层：置于最顶层 -->
        <views:PrivacyOverlay x:Name="AppPrivacyOverlay" Visibility="{x:Bind ViewModel.PrivacyOverlayVisibility, Mode=OneWay}" Canvas.ZIndex="200" />
    </Grid>
</Window>

